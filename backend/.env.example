# Server Configuration
PORT=3002
NODE_ENV=production

# ============================================
# Database Configuration (Choose ONE)
# ============================================
# Without a cloud database, data will be lost on each server restart (Render uses ephemeral filesystem)
# You only need to configure ONE of the following options.

# --- Option A: Supabase (RECOMMENDED - Easiest) ---
# 1. Go to https://supabase.com and sign up (just email, no Google needed)
# 2. Create a new project (free, takes 30 seconds)
# 3. Go to Project Settings > Database > Connection string > URI
# 4. Copy the connection string and replace [YOUR-PASSWORD] with your database password
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# --- Option B: MongoDB Atlas ---
# Get your free MongoDB Atlas connection string at: https://www.mongodb.com/atlas
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
# MONGODB_DB_NAME=qunthink

# Authentication Configuration
# AUTH_MODE: dev (skip auth, use x-user-id header) | session (use session-based auth)
AUTH_MODE=session
# Session max age in milliseconds (default: 2592000000 = 30 days)
SESSION_MAX_AGE=2592000000

# API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key
GLM_API_KEY=your_glm_api_key
MIMO_API_KEY=your_mimo_api_key
QWEN_API_KEY=your_qwen_api_key

# Encryption Key (REQUIRED in production)
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Production: Must set this environment variable, otherwise the application will not start
# Development: If not set, will use file-based key stored in backend/data/.encryption_key
# ⚠️  NEVER commit .env file or .encryption_key file to version control
# ⚠️  Key rotation will invalidate previously encrypted data
ENCRYPTION_KEY=your_encryption_key_base64_encoded_min_32_bytes

# Aliyun SMS Configuration
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code

# CORS Configuration
CORS_ORIGINS=https://your-vercel-app.vercel.app
